# Strapi instance URL (same as used for dversi.com)
# e.g. https://cms.hundredsolutions.com
STRAPI_URL=https://your-strapi-instance.com

# Strapi API token (read-only token from Strapi admin → API Tokens)
STRAPI_API_TOKEN=your_token_here

# Blog content type slug in Strapi (default: articles)
# Change if your Strapi uses a different collection name
STRAPI_COLLECTION=articles
